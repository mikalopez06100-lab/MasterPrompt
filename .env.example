##############################################
# Master Prompt — Variables d'environnement  #
##############################################
#
# Vercel « Needs Attention » : valeur vide ou variable absente pour
# Production / Preview — éditer chaque clé et cocher les bons environnements.

# --- Base de données (Supabase / PostgreSQL) ---
# Connexion directe (5432) — obligatoire pour Prisma (migrations, db push)
DIRECT_URL=""
# Runtime : en local = direct (5432) ; sur Vercel = pooler (6543) avec ?pgbouncer=true
DATABASE_URL=""

# --- Supabase (Auth + Storage + API) ---
# Projet de référence prod : https://vgdspxhuqdfilrkhipvx.supabase.co
NEXT_PUBLIC_SUPABASE_URL="https://vgdspxhuqdfilrkhipvx.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY=""
# Alias acceptés par l’app (intégration Vercel) : DATABASE_SUPABASE_URL, NEXT_PUBLIC_DATABASE_SUPABASE_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=""

# --- Stripe (paiement) ---
STRIPE_SECRET_KEY=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""
STRIPE_WEBHOOK_SECRET=""
# Webhook endpoint à enregistrer dans Stripe : https://www.masterprompt.fr/api/webhooks/stripe
# Événements : checkout.session.completed, checkout.session.async_payment_succeeded
# Checkout serveur (app/api/billing/checkout) : price OU product selon usage Stripe
STRIPE_PRICE_ONE_TIME=""
STRIPE_PRODUCT_ONE_TIME=""
STRIPE_PRICE_SUBSCRIPTION=""
# Payment Links Stripe (pages offres)
NEXT_PUBLIC_STRIPE_LINK_FORMATION=""
NEXT_PUBLIC_STRIPE_LINK_PACK=""
# Promo formation (fin précommande 49€ — défaut code : 30/06/2026)
NEXT_PUBLIC_PROMO_END_DATE=""
NEXT_PUBLIC_LAUNCH_PRICE_ACTIVE="true"
NEXT_PUBLIC_BOOKING_URL=""

# --- Resend (envoi d’emails transactionnels) ---
RESEND_API_KEY=""
# Expéditeur : une seule suffit ; EMAIL_FROM est prioritaire si les deux sont définies
EMAIL_FROM=""
FROM_EMAIL=""
# Boîte qui reçoit les demandes (contact, accompagnement, audit…)
EMAIL_TO=""
# Lead magnet PDF (URL publique Supabase Storage ou autre)
LEAD_MAGNET_PDF_URL=""
# Lien désabonnement dans les templates email
UNSUBSCRIBE_URL="https://www.masterprompt.fr"

# --- Mux (vidéo) ---
MUX_TOKEN_ID=""
MUX_TOKEN_SECRET=""

# --- App ---
# En local : http://localhost:3003
# Sur Vercel : https://ton-domaine.com ou https://ton-projet.vercel.app
NEXT_PUBLIC_APP_URL="http://localhost:3003"
# Liste des emails autorises admin (separes par des virgules)
ADMIN_EMAILS=""
# Vignettes photo de profils (preuve sociale hero) — URLs séparées par des virgules (max 5). Vide = avatars par défaut.
# NEXT_PUBLIC_SOCIAL_AVATARS="https://...,https://...,..."

# Google Search Console — valeur "content" de la balise google-site-verification (sans les guillemets)
# NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION="abc123..."

# --- Brevo (sync contacts / listes — pas l’envoi des mails) ---
BREVO_API_KEY=""
# Liste principale (ex. lead magnet /api/lead-magnet)
BREVO_LIST_ID_MAIN=""
# Page /diagnostic
BREVO_DIAGNOSTIC_LIST_ID=""
# Formulaire Pack IA (/api/contact)
BREVO_LIST_ID_PACK_IA=""
# Formulaire accompagnement
BREVO_LIST_ID_ACCOMPAGNEMENT=""
# Aperçu espace formation (/api/preview-access) ; sinon fallback BREVO_LIST_ID_MAIN
BREVO_LIST_ID_PREVIEW=""
# Liste relance guide 10 prompts (import manuel / script)
BREVO_RELANCE_GUIDE_LIST_ID=""

# --- Vidéo de présentation Formation (Supabase Storage) ---
# Obtenue après exécution de : node scripts/upload-presentation-video-to-supabase.mjs
NEXT_PUBLIC_PRESENTATION_VIDEO_URL=""

# --- Vidéos des modules Formation (Supabase Storage ou URL externe) ---
# Script : node scripts/upload-formation-module-video.mjs <numero>
# Optionnel : FORMATION_VIDEO_BUCKET=assets (nom du bucket Supabase)
# Limite Supabase : plan Free = 50 Mo max par fichier (global). Vidéos longues → plan Pro ou hébergement
# externe (Mux, etc.) puis URL publique ci-dessous.
NEXT_PUBLIC_MODULE_1_VIDEO_URL=""
NEXT_PUBLIC_MODULE_2_VIDEO_URL=""
NEXT_PUBLIC_MODULE_3_VIDEO_URL=""
NEXT_PUBLIC_MODULE_4_VIDEO_URL=""
NEXT_PUBLIC_MODULE_5_VIDEO_URL=""
NEXT_PUBLIC_MODULE_6_VIDEO_URL=""
NEXT_PUBLIC_MODULE_7_VIDEO_URL=""

# --- Espace propositions privées ---
# Token unique pour l'accès aux pages /propositions/[slug]
PROPOSAL_ACCESS_TOKEN=""

# --- Claude (Anthropic API) ---
ANTHROPIC_API_KEY=""
# Modele recommande
ANTHROPIC_MODEL="claude-3-5-sonnet-20241022"

# --- Correcteur de prompts PACO ---
CORRECTOR_QUOTA=20                 # corrections par mois civil
CORRECTOR_TRIAL_MONTHS=3           # durée de la période d'essai (mois)
CORRECTOR_SUB_PRICE=4.90           # prix mensuel abonnement (V2)
CORRECTOR_SUBSCRIBE_URL=""         # page d'abonnement / liste d'attente V1
NEXT_PUBLIC_CORRECTOR_SUB_PRICE="4,90"  # affiché côté client (formaté FR)
